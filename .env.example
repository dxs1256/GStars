# 必填 要抓取 Stars 的 GitHub 用户名
GH_USERNAME=your-github-username
# 强烈建议填写 GitHub Token，否则 API 限速（60次/小时）会导致同步失败
GH_TOKEN=your-github-personal-access-token

# 必填 AI 配置
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=gpt-4o-mini
# 必填 并发数
MAX_CONCURRENCY=1
# 可选 单次 AI 请求超时（秒）
AI_TIMEOUT=60
# 可选 单个仓库 AI 重试次数
AI_MAX_RETRIES=5
# 可选 指数退避基础延迟（秒）
AI_RETRY_BASE_DELAY=1
# 可选 指数退避最大延迟（秒）
AI_RETRY_MAX_DELAY=20
# 可选 两次 AI 请求之间的最小间隔（秒）
AI_MIN_REQUEST_INTERVAL=0.5
# 可选 同时在途的 AI 请求数
AI_MAX_IN_FLIGHT=2

# 输出配置
# 必填 生成 Markdown 的基准文件名 (自动补全 _zh/_en)
OUTPUT_FILENAME=stars          

# VAULT_SYNC_ENABLED 开启后必填 Vault 同步配置 (可选)
VAULT_SYNC_ENABLED=false
VAULT_REPO=username/vault-repo
# Vault 里的目标文件夹
VAULT_SYNC_PATH=GitHub-Stars/
# 有 Vault 仓库 Contents: Write 权限的 Fine-grained PAT
VAULT_PAT=your-vault-pat 

# GitHub Pages 同步配置 (可选)
# 开启后会将生成的 HTML / MD 部署到 gh-pages 分支
PAGES_SYNC_ENABLED=true

# 测试限制 (可选)
# 留空则处理所有 Stars，填写数字则仅处理前 N 个新项目
TEST_LIMIT=5
